# ============================================================
# Aurea Backend - Variables de entorno (ejemplo)
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# ---------- Servidor ----------
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# ---------- Base de datos (MongoDB) ----------
# MONGO_URI=mongodb://localhost:27017/aurea
MONGO_URI=mongodb+srv://elenaarranzhernan_db_user:8cXX7Kh10XYVS0BE@cluster0.qtvlpgk.mongodb.net/aurea?retryWrites=true&w=majority&appName=Cluster0
MONGO_DB_NAME=aurea

# ---------- Autenticación JWT ----------
JWT_SECRET=cambia-esto-por-una-clave-segura-de-al-menos-32-caracteres
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=cambia-esto-por-otra-clave-segura
JWT_REFRESH_EXPIRES_IN=30d

# ---------- Seguridad / CORS ----------
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
BCRYPT_SALT_ROUNDS=12

# ---------- Subida de archivos ----------
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ---------- Email (para recuperar contraseñas, confirmaciones) ----------
